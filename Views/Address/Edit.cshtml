@model AddressManager.ViewModels.EnderecoViewModel
@{
    ViewData["Title"] = "Editar Endereço";
}

<div class="page-container" style="max-width:780px">

  <div class="page-header">
    <div>
      <div class="page-subtitle">Edição</div>
      <h1>Editar <span>Endereço</span></h1>
    </div>
    <a asp-action="Index" class="btn btn-ghost btn-sm">← Voltar</a>
  </div>

  <form asp-action="Edit" asp-route-id="@Model.Id" method="post" novalidate>
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    @await Html.PartialAsync("_AddressForm", Model)

    <div class="d-flex gap-2 mt-2" style="justify-content:flex-end">
      <a asp-action="Index" class="btn btn-ghost">Cancelar</a>
      <button type="submit" class="btn btn-primary">Atualizar Endereço</button>
    </div>
  </form>

</div>
